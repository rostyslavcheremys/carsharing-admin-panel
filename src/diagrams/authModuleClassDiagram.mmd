classDiagram
    direction TB

    class User {
        +String id
        +String email
        +String firstName
        +String lastName
        +String phoneNumber
        +String role
        +String verificationStatus
        +Boolean isBlocked
        +Timestamp birthDate
        +Timestamp createdAt
    }

    class Firebase {
        <<infrastructure>>
        +Auth auth
        +Firestore db
        +Functions functions
    }

    class AuthService {
        <<service>>
        +login(email: String, password: String) User
        +register(data: Object) User
        +logout() void
    }

    class UserService {
        <<service>>
        +getUser(id: String) User
        +approveUser(userId: String) void
        +blockUser(userId: String, isBlocked: Boolean) void
        +deleteUser(userId: String) void
    }

    class AuthProvider {
        <<context>>
        -user: User | null
        -loading: Boolean
        -error: Error | null
        +setUser(user: User) void
        +logout() void
    }

    class useAuth {
        <<hook>>
        +user: User | null
        +loading: Boolean
        +error: Error | null
        +setUser(user: User) void
        +logout() void
    }

    class LoginPage {
        <<page>>
        +onSubmit(email: String, password: String) void
    }

    class RegisterPage {
        <<page>>
        +onSubmit(data: Object) void
    }

    class DriverVerificationPage {
        <<page>>
        +handleVerify() void
        +handleClose() void
    }

    class ProtectedRoute {
        <<component>>
        +adminOnly: Boolean
        +userOnly: Boolean
        +render() Component
    }

    class PublicRoute {
        <<component>>
        +redirectTo: String
        +render() Component
    }

    AuthService --> Firebase : uses
    UserService --> Firebase : uses

    AuthService --> User : returns
    UserService --> User : manages

    AuthProvider --> AuthService : calls
    AuthProvider --> UserService : calls

    useAuth --> AuthProvider : consumes context

    LoginPage --> AuthService : login()
    RegisterPage --> AuthService : register()
    DriverVerificationPage --> UserService : approveUser()

    ProtectedRoute --> useAuth : checks auth
    PublicRoute --> useAuth : checks auth