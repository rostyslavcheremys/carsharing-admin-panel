---
config:
  theme: neutral
  look: classic
  themeVariables:
    fontSize: 20px
---

classDiagram

    class User {
        <<document>>
    }

    class Car {
        <<document>>
    }

    class Booking {
        <<document>>
    }

    class Trip {
        <<document>>
    }

    class CarCondition {
        <<document>>
    }

    class AuthService {
        <<service>>
        +login(email, password) Promise~User~
        +register(data) Promise~User~
    }

    class UserService {
        <<service>>
        +approve(userId) Promise~void~
        +getUserById(userId) Promise~User~
        +setBlocked(userId, isBlocked) Promise~void~
        +delete(userId) Promise~Object~
    }

    class CarService {
        <<service>>
        +create(data) Promise~Car~
        +update(carId, data, images) Promise~Car~
        +delete(carId) Promise~void~
        +getCarById(carId) Promise~Car~
        +toggleLock(carId, isLocked) Promise~Car~
        +lock(carId) Promise~void~
        +unlock(carId) Promise~void~
    }

    class BookingService {
        <<service>>
        +create(data) Promise~Booking~
        +confirm(bookingId) Promise~void~
        +cancel(bookingId) Promise~void~
        +delete(bookingId) Promise~void~
        +getActiveBookingByUser(userId) Promise~Booking~
    }

    class TripService {
        <<service>>
        +start(bookingData) Promise~TripId~
        +end(tripId) Promise~Trip~
        +pay(tripId) Promise~void~
        +delete(tripId) Promise~void~
        +getActiveTripByUser(userId) Promise~Trip~
    }

    class CarConditionService {
        <<service>>
        +save(trip, data, type) Promise~CarCondition~
    }

    class Firestore {
        <<infrastructure>>
        +Collection users
        +Collection cars
        +Collection bookings
        +Collection trips
        +Collection carConditions
    }

    class FirebaseAuth {
        <<infrastructure>>
    }

    AuthService ..> FirebaseAuth : auth
    AuthService ..> Firestore : users

    UserService ..> Firestore : users
    CarService ..> Firestore : cars
    BookingService ..> Firestore : bookings
    TripService ..> Firestore : trips
    CarConditionService ..> Firestore : carConditions

    UserService --> User : manages
    CarService --> Car : manages
    BookingService --> Booking : manages
    TripService --> Trip : manages
    CarConditionService --> CarCondition : manages

    Booking --> User : userId
    Booking --> Car : carId
    Booking --> Trip : tripId

    Trip --> Booking : bookingId
    Trip --> User : userId
    Trip --> Car : carId
    Trip --> CarCondition : startConditionId
    Trip --> CarCondition : endConditionId

    CarCondition --> User : userId
    CarCondition --> Car : carId
    CarCondition --> Trip : tripId