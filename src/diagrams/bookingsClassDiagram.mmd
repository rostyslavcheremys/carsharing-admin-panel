classDiagram
    direction TB

    class BookingPeriodPage {
        <<page>>
        +car: Car
        +plannedStart: Date
        +plannedEnd: Date
        +totalPrice: Number
        +handleSubmit()
    }

    class BookingPaymentPage {
        <<page>>
        +booking: Booking
        +timeLeft: String
        +handlePay()
        +handleCancel()
    }

    class BookingConfirmationPage {
        <<page>>
        +booking: Booking
        +car: Car
    }

    class CarDetailsDialog {
        <<component>>
        +car: Car
        +onClose()
    }

    class BookingService {
        <<service>>
        +create(data) Promise~Booking~
        +confirm(id) Promise~void~
        +cancel(id) Promise~void~
        +getActiveBookingByUser(id) Promise~Booking~
    }

    class useActiveBooking {
        <<hook>>
        +activeCarId: String
    }

    class useCountdown {
        <<hook>>
        +timeLeft: String
    }

    class useMessageDialog {
        <<hook>>
        +showMessage(text)
    }

    class calculateBookingDays {
        <<utility>>
        +start: Date
        +end: Date
        +returns: Number
    }

    class Firestore {
        <<infrastructure>>
        +bookings
        +cars
    }

    BookingPeriodPage ..> BookingService : create
    BookingPeriodPage ..> calculateBookingDays
    BookingPeriodPage ..> useMessageDialog
    BookingPeriodPage --> BookingPaymentPage

    BookingPaymentPage ..> BookingService : confirm/cancel
    BookingPaymentPage ..> useCountdown
    BookingPaymentPage --> BookingConfirmationPage

    CarDetailsDialog --> BookingPeriodPage

    BookingService ..> Firestore

    useActiveBooking ..> Firestore